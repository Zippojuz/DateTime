  "quests": {
    "prospectus": {
      "id": "prospectus",
      "giver": "ines",
      "name": "No Fault Found, Redux",
      "book": "ministry_prospectus",
      "unlocks": "sys_401",
      "brief": "Professor Halloran wants the annotated Ministry Holdings prospectus \u2014 the real one, not the sanitized reissue. It went into the Substrate with the person who wrote it. Bring it up.",
      "turn_in": "She weighs the folio like it might be warm. \"Forty years. Alright. Sit down \u2014 you've earned the seminar no one's allowed to take.\"",
      "flag": "quest:prospectus:done",
      "reward_credits": 0
    },
    "founders_library": {
      "id": "founders_library",
      "giver": "ines",
      "name": "The Founder's Library",
      "set": [
        "folio_founders_1",
        "folio_founders_2",
        "folio_founders_3",
        "folio_founders_4"
      ],
      "unlocks": "fnd_401",
      "brief": "Four volumes, scattered when the college was nearly bought out: a founder hid them across the city rather than let the corps pulp them. Halloran has spent a career tracing where. Assemble the set.",
      "turn_in": "She sets the four spines together and exhales like she's been holding it since before you were born. \"There. Whole. Come \u2014 let me show you what they were so afraid of.\"",
      "flag": "quest:founders_library:done",
      "reward_credits": 200
    }
  }
